# Rest Client

@hostname = http://127.0.0.1
@port = 8000
@pathType = api
@pathVersion = v1
@host = {{hostname}}:{{port}}
@baseUrl = {{host}}/{{pathType}}/{{pathVersion}}
@authService = auth
@userAgent = Mozilla/5.0 (X11; Linux x86_64; rv:145.0) Gecko/20100101 Firefox/145.0
@typeAuthorization = {{authLogin.response.body.data.$.type_token}}
@accessAuthorization = {{authLogin.response.body.data.$.access_token}}
# @authorization = {{typeAuthorization}} {{accessAuthorization}}
@authorization = Bearer eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9..NohALLmyrG85HRXvV77th9X6vtsf8jGyask1dmEUVMc


### Check API Apps Auth Service
GET {{baseUrl}}/{{authService}} HTTP/1.1
Accept: application/json
User-Agent: {{userAgent}}


### Check Health Apps Auth Service
GET {{baseUrl}}/{{authService}}/health HTTP/1.1
Accept: application/json
User-Agent: {{userAgent}}


### Auth Login
# @name authLogin
@email = admin@getnada.com
@password = 123456789
POST {{baseUrl}}/{{authService}}/login HTTP/1.1
Accept: application/json
User-Agent: {{userAgent}}
Content-Type: application/json

{
    "email": "{{email}}",
    "password": "{{password}}"
}


### Auth Menu Logout
DELETE {{baseUrl}}/{{authService}}/logout HTTP/1.1
Accept: application/json
Authorization: {{authorization}}
User-Agent: {{userAgent}}


### Auth Menu Profile Signin
GET {{baseUrl}}/{{authService}}/user HTTP/1.1
Accept: application/json
Authorization: {{authorization}}
User-Agent: {{userAgent}}


### Auth Menu Signin
GET {{baseUrl}}/{{authService}}/menus HTTP/1.1
Accept: application/json
Authorization: {{authorization}}
User-Agent: {{userAgent}}


### Auth Internal Menu Signin (Communication for Services)
GET {{baseUrl}}/{{authService}}/internal/menus HTTP/1.1
Accept: application/json
Authorization: {{authorization}}
User-Agent: {{userAgent}}


### Auth Internal Has Access Permission (Communication for Services)
POST {{baseUrl}}/{{authService}}/internal/has-access HTTP/1.1
Accept: application/json
Authorization: {{authorization}}
User-Agent: {{userAgent}}
Content-Type: application/json

{
    "permission_slug": "1",
    "route_name": "1"
}

